PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
WHATSAPP_PROVIDER=dummy

# Twilio WhatsApp Sandbox or approved Twilio WhatsApp sender
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_PLAN_CONTENT_SID=

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=abc-gym-local-token
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Razorpay
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Sheets API
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Members!A:K
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Optional admin protection for /members and /export
ADMIN_TOKEN=
OWNER_PHONE=
OWNER_REMINDER_DAYS=7
